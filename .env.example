# SIS Scraper Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LOCAL DATABASE
# =============================================================================
# Path to SQLite output database (default: ./data/curriculum.db)
# SISIA_DB_PATH=./data/curriculum.db

# =============================================================================
# SUPABASE / DATABASE INTEGRATION
# =============================================================================
# Supabase ingest endpoint URL
# SUPABASE_INGEST_ENDPOINT=https://your-project.supabase.co/functions/v1/ingest

# Bearer token for data ingestion endpoint
# DATA_INGEST_TOKEN=your_ingest_token_here

# Batch size for Supabase uploads (default: 2000)
# SUPABASE_CLIENT_BATCH_SIZE=2000

# =============================================================================
# GOOGLE SHEETS INTEGRATION
# =============================================================================
# Service account JSON (as a single-line string)
# GOOGLE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Target spreadsheet ID
# SPREADSHEET_ID=your_spreadsheet_id_here

# =============================================================================
# SCRAPER CONFIGURATION
# =============================================================================
# Number of concurrent workers for PDF processing (default: 2)
# CURRICULUM_CONCURRENCY=2

# Delay in milliseconds between HTTP requests during discovery (default: 100)
# CURRICULUM_DELAY_MS=100

# Optional: Limit the number of PDFs processed (useful for testing)
# CURRICULUM_LIMIT=10

# Optional: Filter to specific program identifiers (comma-separated)
# CURRICULUM_SAMPLE=social-work,computer-science

# Enable HEAD probe for non-.pdf URLs with download keywords (default: true)
# ENABLE_HEAD_PROBE=true

# =============================================================================
# BASELINE & REGRESSION DETECTION
# =============================================================================
# Percentage drop threshold for regression detection (default: 10)
# BASELINE_DROP_THRESHOLD=10

# If true, only warn about regressions without failing (default: false)
# BASELINE_WARN_ONLY=false

# =============================================================================
# SYNC SETTINGS
# =============================================================================
# Number of concurrent requests for Supabase sync (default: 5)
# SCHEDULE_SEND_CONCURRENCY=5

# =============================================================================
# LLM PARSER (Gemini)
# =============================================================================
# Enable the LLM-assisted PDF parser as an alternative/fallback (default: false)
# LLM_PARSER_ENABLED=false

# Gemini model to use (default: gemini-3-flash-preview)
# LLM_MODEL=gemini-3-flash-preview

# --- Vertex AI backend (preferred) ---
# Path to Google service account key JSON
# GOOGLE_APPLICATION_CREDENTIALS=./google-sa-key.json

# Google Cloud project ID for Vertex AI (default: bygelo-3)
# VERTEX_PROJECT=bygelo-3

# Google Cloud region for Vertex AI (default: global)
# Note: gemini-3-flash-preview requires 'global' region
# VERTEX_LOCATION=global

# --- Google AI Studio backend (fallback) ---
# API key from https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# DEBUGGING
# =============================================================================
# Enable debug logging (default: false)
# DEBUG_SCRAPER=false
